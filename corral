def do_init():
    config_path = Path("corral.toml")
    if config_path.exists():
        print("corral.toml already exists — leaving it", file=sys.stderr)
    else:
        config_path.write_text(SCAFFOLD_CONFIG)
        print("wrote corral.toml")
    hooks = Path("hooks")
    hooks.mkdir(exist_ok=True)
    for name, body in SCAFFOLD_HOOKS.items():
        path = hooks / name
        if path.exists():
            continue
        path.write_text(body)
        path.chmod(0o755)
        print(f"wrote hooks/{name}")
    return 0


def main():
    parser = argparse.ArgumentParser(prog="corral", description="ephemeral box broker + resource queue")
    parser.add_argument("-c", "--config", default="corral.toml")
    sub = parser.add_subparsers(dest="cmd", required=True)
    sub.add_parser("init", help="scaffold corral.toml + hooks/ into the current dir")
    allocate = sub.add_parser("allocate", help="get a box for KEY (clones on demand)")
    allocate.add_argument("key")
    allocate.add_argument("--kind", choices=["shared", "clone"], default="clone")
    release = sub.add_parser("release", help="tear down the box for KEY")
    release.add_argument("key")
    sub.add_parser("list", help="show the pool")
    reap = sub.add_parser("reap", help="destroy clones older than --ttl minutes")
    reap.add_argument("--ttl", type=int, default=120)
    resource = sub.add_parser("resource", help="run a command holding a named lock")
    resource.add_argument("name")
    resource.add_argument("cmd", nargs=argparse.REMAINDER)
    args = parser.parse_args()

    if args.cmd == "init":
        return do_init()

    config = load_config(args.config)
    sd = state_dir(config)
    provider = make_provider(config, sd)
    handlers = {
        "allocate": cmd_allocate,
        "release": cmd_release,
        "list": cmd_list,
        "reap": cmd_reap,
        "resource": cmd_resource,
    }
    return handlers[args.cmd](config, provider, sd, args)


if __name__ == "__main__":
    sys.exit(main())
